<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/dimen_20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tvInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="3"
                    android:text="@string/work_order_history_info"
                    android:textColor="@color/black"
                    android:textSize="@dimen/label_text_size"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvHours"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/dimen_15dp"
                    android:text="@string/_0_hr"
                    android:textColor="@color/black"
                    android:textSize="@dimen/label_text_size"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvInfo" />

                <TextView
                    android:id="@+id/tvTimeWorkedPrevious"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:textSize="@dimen/label_text_size"
                    android:visibility="gone"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvHours" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clWo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/clInfo">

                <TextView
                    android:id="@+id/lblWorkOrder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/work_order"
                    android:textColor="@color/black"
                    android:textSize="20sp"
                    android:textStyle="italic"
                    app:layout_constraintBaseline_toBaselineOf="@id/acWorkOrder"
                    app:layout_constraintEnd_toStartOf="@id/acWorkOrder"
                    app:layout_constraintStart_toStartOf="parent" />

                <AutoCompleteTextView
                    android:id="@+id/acWorkOrder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:hint="@string/type_numbers"
                    android:minWidth="@dimen/text_box_medium"
                    android:minHeight="@dimen/minimum_touch_height"
                    android:paddingStart="@dimen/dimen_10dp"
                    android:paddingEnd="@dimen/dimen_5dp"
                    android:selectAllOnFocus="true"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toStartOf="@id/btnWorkOrder"
                    app:layout_constraintStart_toEndOf="@id/lblWorkOrder"
                    app:layout_constraintTop_toTopOf="parent" />

                <Button
                    android:id="@+id/btnWorkOrder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/dark_green"
                    android:text="@string/create"
                    app:layout_constraintBaseline_toBaselineOf="@id/acWorkOrder"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/acWorkOrder" />

                <TextView
                    android:id="@+id/tvWoInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="3"
                    android:text="@string/work_order_summary"
                    android:textColor="@color/black"
                    android:textSize="@dimen/label_text_size"
                    android:visibility="gone"
                    app:layout_constraintStart_toStartOf="@id/lblWorkOrder"
                    app:layout_constraintTop_toBottomOf="@id/acWorkOrder" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clStart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/dimen_20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/clWo">

                <TextView
                    android:id="@+id/lblStartTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/start_time"
                    android:textColor="@color/black"
                    android:textSize="@dimen/text_size_large"
                    android:textStyle="bold"
                    app:layout_constraintBaseline_toBaselineOf="@id/tvTotalTime"
                    app:layout_constraintEnd_toStartOf="@id/clkStartTime"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/clkStartTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:textSize="@dimen/text_size_large"
                    android:textStyle="bold"
                    app:layout_constraintBaseline_toBaselineOf="@id/tvTotalTime"
                    app:layout_constraintEnd_toStartOf="@id/tvTotalTime"
                    app:layout_constraintStart_toEndOf="@id/lblStartTime" />

                <TextView
                    android:id="@+id/tvTotalTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/total_time"
                    android:textColor="@color/deep_red"
                    android:textSize="@dimen/text_size_small"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/clkStartTime"
                    app:layout_constraintTop_toTopOf="parent" />


            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clEnd"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/dimen_20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/clStart">

                <TextView
                    android:id="@+id/lblEndTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/end_time"
                    android:textColor="@color/black"
                    android:textSize="@dimen/text_size_large"
                    android:textStyle="bold"
                    app:layout_constraintBaseline_toBaselineOf="@id/btnEnterTime"
                    app:layout_constraintEnd_toStartOf="@id/clkEndTime"
                    app:layout_constraintStart_toStartOf="parent" />

                <TextView
                    android:id="@+id/clkEndTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:textSize="@dimen/text_size_large"
                    android:textStyle="bold"
                    app:layout_constraintBaseline_toBaselineOf="@id/btnEnterTime"
                    app:layout_constraintEnd_toStartOf="@id/btnEnterTime"
                    app:layout_constraintStart_toEndOf="@id/lblEndTime" />

                <Button
                    android:id="@+id/btnEnterTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/dark_green"
                    android:text="@string/enter_time"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/clkEndTime"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clHourType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/clEnd">

                <RadioGroup
                    android:id="@+id/radHourType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <RadioButton
                        android:id="@+id/radRegHours"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/minimum_touch_height"
                        android:checked="true"
                        android:text="@string/reg_hours"
                        android:textStyle="bold"
                        android:value="1" />

                    <RadioButton
                        android:id="@+id/radOtHours"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/minimum_touch_height"
                        android:text="@string/ot_hrs"
                        android:textStyle="bold"
                        android:value="2" />

                    <RadioButton
                        android:id="@+id/radDblOtHours"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/minimum_touch_height"
                        android:text="@string/dbl_ot_hrs"
                        android:textStyle="bold"
                        android:value="3" />

                    <RadioButton
                        android:id="@+id/radBreak"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/minimum_touch_height"
                        android:text="@string/_break"
                        android:textStyle="bold"
                        android:value="0" />
                </RadioGroup>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTimeWorked"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/dimen_15dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/clHourType" />

            <View
                android:id="@+id/vSpacer"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dimen_75dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/rvTimeWorked" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabDone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_25dp"
                android:layout_marginEnd="@dimen/dimen_25dp"
                android:backgroundTint="@color/dark_green"
                android:contentDescription="@string/done"
                android:src="@drawable/ic_done"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</layout>