<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".ui.workorder.workorderHistory.WorkOrderHistoryWorkPerformedUpdateFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/frameLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/tvInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/dimen_10dp"
            android:padding="@dimen/dimen_8dp"
            android:text="@string/work_performed"
            android:textColor="@color/black"
            android:textSize="@dimen/text_size_large"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/vSpacer"
            android:layout_width="0dp"
            android:layout_height="@dimen/dimen_8dp"
            android:backgroundTint="@color/black"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvInfo" />

        <TextView
            android:id="@+id/lblWorkPerformed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dimen_25dp"
            android:layout_marginTop="@dimen/dimen_25dp"
            android:text="@string/work_performed"
            android:textColor="@color/black"
            android:textSize="@dimen/text_size_medium"
            android:textStyle="italic"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/vSpacer" />

        <AutoCompleteTextView
            android:id="@+id/acWorkPerformed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:hint="@string/work_performed"
            android:importantForAutofill="no"
            android:inputType="textMultiLine|textCapSentences"
            android:maxWidth="@dimen/text_box_extra_wide"
            android:minHeight="@dimen/minimum_touch_height"
            android:paddingStart="@dimen/dimen_20dp"
            android:paddingEnd="@dimen/dimen_20dp"
            android:selectAllOnFocus="true"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/lblWorkPerformed"
            tools:ignore="DuplicateSpeakableTextCheck" />

        <TextView
            android:id="@+id/lblArea"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dimen_25dp"
            android:text="@string/area"
            android:textColor="@color/black"
            android:textSize="@dimen/text_size_medium"
            android:textStyle="italic"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/acWorkPerformed" />

        <AutoCompleteTextView
            android:id="@+id/acArea"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:hint="@string/area_optional"
            android:importantForAutofill="no"
            android:inputType="textMultiLine|textCapSentences"
            android:maxWidth="@dimen/text_box_medium"
            android:minHeight="@dimen/minimum_touch_height"
            android:paddingStart="@dimen/dimen_20dp"
            android:paddingEnd="@dimen/dimen_20dp"
            android:selectAllOnFocus="true"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/lblArea"
            tools:ignore="DuplicateSpeakableTextCheck" />

        <EditText
            android:id="@+id/etWorkPerformedNote"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="@string/enter_note_optional"
            android:importantForAutofill="no"
            android:inputType="textMultiLine|textCapSentences"
            android:maxWidth="@dimen/layout_width_wide"
            android:maxLines="3"
            android:minHeight="@dimen/minimum_touch_height"
            android:paddingStart="@dimen/dimen_20dp"
            android:paddingEnd="@dimen/dimen_20dp"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/acArea"
            tools:ignore="VisualLintTextFieldSize" />

        <Button
            android:id="@+id/btnUpdate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/green"
            android:text="@string/update"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/etWorkPerformedNote"
            tools:ignore="TextContrastCheck,DuplicateSpeakableTextCheck" />


    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>